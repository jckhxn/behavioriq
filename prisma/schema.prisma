// Conversational Assessment Session - Persistent storage with API abuse safeguards
model ConversationalSession {
  id                     String    @id @default(cuid())
  assessmentId           String    @unique // Each assessment can have one conversational session
  userId                 String?
  currentQuestionIndex   Int       @default(0)
  responses              Json      // Record<string, boolean> - questionId -> answer
  messages               Json      // ConversationalMessage[] - Full message history
  isComplete             Boolean   @default(false)
  isTrial                Boolean   @default(false)
  questions              Json      // Question[] - Cached questions for this session
  totalTokenUsage        Json?     // TokenUsage object with prompt/completion/total
  clarificationAttempts  Int       @default(0)
  lastSubmittedAt        DateTime? // Last time user submitted a response (for rate limiting)
  submissionCount        Int       @default(0) // Total number of submissions (for monitoring abuse)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  assessment             Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user                   User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions            ConversationalSubmission[]

  @@index([userId])
  @@index([assessmentId])
  @@index([updatedAt])
  @@index([isComplete])
  @@map("conversational_sessions")
}

// Track each question submission for idempotency and audit trail
model ConversationalSubmission {
  id                String                @id @default(cuid())
  sessionId         String
  questionId        String
  questionIndex     Int
  userResponse      String                // The actual text user submitted
  extractedAnswer   Boolean?              // true/false/null (null = unclear)
  confidence        Float
  wasRecorded       Boolean               @default(false) // Whether this answer was recorded in session.responses
  tokenUsage        Json?                 // TokenUsage for this submission
  submittedAt       DateTime              @default(now())

  session           ConversationalSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Idempotency: Prevent exact duplicate submissions
  @@unique([sessionId, questionId, userResponse])
  @@index([sessionId])
  @@index([questionId])
  @@index([submittedAt])
  @@map("conversational_submissions")
}

