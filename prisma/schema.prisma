generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  extensions        = [vector]
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?
  password        String
  role            Role             @default(USER)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  isActive        Boolean          @default(true)
  lastLoginAt     DateTime?
  organizationId  String?
  parentUserId    String?          // For sub-accounts, references the district admin who created them
  onboardingCompleted Boolean      @default(false)
  onboardingStep      Int          @default(0)
  onboardingSkipped   Boolean      @default(false)
  stripeCustomerId    String?      @unique
  assessments     Assessment[]
  chatSessions    ChatSession[]
  documents       Document[]
  recommendations Recommendation[]
  shareLinks      ShareableLink[]  @relation("ShareLinksCreated")
  usageMetrics    UsageMetrics[]
  licenses        UserLicense[]
  upsellState     UserUpsellState?
  telemetryEvents TelemetryEvent[]
  payments        Payment[]
  organization    Organization?    @relation(fields: [organizationId], references: [id])
  parentUser      User?            @relation("UserSubAccounts", fields: [parentUserId], references: [id])
  subAccounts     User[]           @relation("UserSubAccounts")
  managedSubAccounts SubAccount[]  @relation("ManagedBy")
  subAccountProfile SubAccount?    @relation("SubAccountUser")
  generatedAIReports AIReport[]
  createdAssessmentTemplates AssessmentTemplate[] @relation("AssessmentTemplatesCreated")
  createdDomainTemplates DomainTemplate[] @relation("DomainTemplatesCreated")
  createdAssessmentVersions AssessmentTemplateVersion[] @relation("AssessmentVersionsCreated")
  createdDomainVersions DomainTemplateVersion[] @relation("DomainVersionsCreated")
  loginTokens     LoginToken[]
  createdResources ResourceLibrary[] @relation("ResourceLibraryCreator")
  passkeys        Passkey[]
  conversationalSessions ConversationalSession[]
  emailLogs       EmailLog[]
  notificationPreferences NotificationPreferences?

  @@index([organizationId])
  @@index([parentUserId])
  @@map("users")
}

model Passkey {
  id                String   @id @default(cuid())
  userId            String
  name              String   // User-friendly name (e.g., "iPhone 13", "MacBook Pro")
  credentialId      String   @unique // Base64URL encoded credential ID
  publicKey         String   // Base64URL encoded public key
  counter           BigInt   // Signature counter for replay protection
  transports        String[] // Supported transports (e.g., ["usb", "nfc", "ble", "internal"])
  createdAt         DateTime @default(now())
  lastUsed          DateTime @default(now())
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([credentialId])
  @@map("passkeys")
}

model PasskeyChallenge {
  id          String   @id @default(cuid())
  userId      String
  challenge   String   @unique // Base64URL encoded challenge
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([challenge])
  @@index([expiresAt])
  @@map("passkey_challenges")
}

model SubAccount {
  id                String         @id @default(cuid())
  userId            String         @unique
  managedByUserId   String         // District admin who manages this sub-account
  organizationId    String
  displayName       String         // Custom name for this sub-account
  description       String?        // Description of the sub-account purpose
  maxAssessments    Int?           // Limit on assessments for this sub-account
  maxUsers          Int            @default(1) // Number of users this sub-account can have
  settings          Json?          // Custom settings for the sub-account
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  user              User           @relation("SubAccountUser", fields: [userId], references: [id], onDelete: Cascade)
  managedBy         User           @relation("ManagedBy", fields: [managedByUserId], references: [id], onDelete: Cascade)
  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([managedByUserId])
  @@index([organizationId])
  @@index([isActive])
  @@map("sub_accounts")
}

model Document {
  id         String           @id @default(cuid())
  title      String
  fileName   String
  fileType   String
  fileSize   Int
  category   DocumentCategory @default(OTHER)
  content    String?
  userId     String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  chunks     DocumentChunk[]
  uploadedBy User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@map("documents")
}

model DocumentChunk {
  id         String                 @id @default(cuid())
  title      String
  content    String
  category   DocumentCategory
  chunkIndex Int
  embedding  Unsupported("vector")?
  documentId String
  userId     String
  createdAt  DateTime               @default(now())
  document   Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId])
  @@map("document_chunks")
}

model Assessment {
  id                      String             @id @default(cuid())
  userId                  String
  subjectName             String
  status                  AssessmentStatus   @default(IN_PROGRESS)
  startedAt               DateTime           @default(now())
  completedAt             DateTime?
  currentDomain           AssessmentDomain?  // Keep for backward compatibility during migration
  currentQuestionOrder    Int?
  shortId                 String?            @unique
  assessmentTemplateId    String?            // Reference to the template this assessment was created from
  isConversational        Boolean            @default(false) // Whether this is a conversational trial
  hasEnhancedReport       Boolean            @default(false) // Whether user purchased enhanced report
  enhancedReportPurchasedAt DateTime?       // When enhanced report was purchased
  childResponses          Json?              // Store child's conversational responses
  enhancedAnalysis        Json?              // Store AI-generated enhanced analysis
  user                    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentTemplate      AssessmentTemplate? @relation("AssessmentFromTemplate", fields: [assessmentTemplateId], references: [id])
  messages                ChatMessage[]
  responses               QuestionResponse[]
  recommendations         Recommendation[]
  scores                  Score[]
  shareableLinks          ShareableLink[]
  aiReport                AIReport?
  conversationalSession   ConversationalSession? // Conversational AI session data

  @@index([userId])
  @@index([status])
  @@index([shortId])
  @@index([assessmentTemplateId])
  @@index([hasEnhancedReport])
  @@unique([userId, subjectName, status, isConversational], name: "unique_inprogress_conversational_assessment")
  @@map("assessments")
}

model AIReport {
  id                    String        @id @default(cuid())
  assessmentId          String        @unique
  content               String        // AI-generated recommendations content
  summary               String?       // Executive summary
  riskLevel             RiskLevel     // Overall risk level
  generatedAt           DateTime      @default(now())
  generatedByUserId     String
  reportOptions         Json          // Stored report options used for generation
  pdfPath               String?       // Path to stored PDF file if generated
  pdfSize               Int?          // Size of PDF in bytes
  emailsSent            Int           @default(0) // Track how many times emailed
  lastAccessedAt        DateTime?     // Track when report was last viewed
  isArchived            Boolean       @default(false)
  
  assessment            Assessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  generatedBy           User          @relation(fields: [generatedByUserId], references: [id])

  @@index([assessmentId])
  @@index([generatedByUserId])
  @@index([generatedAt])
  @@map("ai_reports")
}

// Assessment Templates - Admin-created assessment configurations
model AssessmentTemplate {
  id                    String                        @id @default(cuid())
  name                  String                        // Assessment display name
  slug                  String                        @unique // URL-friendly identifier
  description           String?                       // Assessment description
  instructions          String?                       // Instructions for taking the assessment
  isActive              Boolean                       @default(true) // Whether users can see/take this assessment
  version               Int                           @default(1) // Version number
  createdById           String                        // Admin who created this template
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  
  // Relationships
  createdBy             User                          @relation("AssessmentTemplatesCreated", fields: [createdById], references: [id])
  domains               AssessmentTemplateDomain[]    // Many-to-many with domains
  assessments           Assessment[]                  @relation("AssessmentFromTemplate") // User assessments taken from this template
  versions              AssessmentTemplateVersion[]   // Version history
  
  // Global platform settings relations
  globalTrialSettings   PlatformSettings[]            @relation("GlobalTrialAssessment")
  globalRegularSettings PlatformSettings[]            @relation("GlobalRegularAssessment")

  @@index([createdById])
  @@index([isActive])
  @@index([slug])
  @@map("assessment_templates")
}

// Domain Templates - Reusable domain configurations
model DomainTemplate {
  id                    String                        @id @default(cuid())
  name                  String                        // Domain display name (e.g., "Attention", "Violence Risk")
  slug                  String                        @unique // URL-friendly identifier
  description           String?                       // Domain description
  questions             Json                          // Array of question objects with scoring rules
  resources             Json?                         // Recommended resources and citations for this domain
  scoringConfig         Json                          // Scoring configuration (thresholds, risk levels, etc.)
  version               Int                           @default(1) // Version number
  createdById           String                        // Admin who created this domain
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  
  // Relationships  
  createdBy             User                          @relation("DomainTemplatesCreated", fields: [createdById], references: [id])
  assessmentTemplates   AssessmentTemplateDomain[]    // Many-to-many with assessment templates
  versions              DomainTemplateVersion[]       // Version history
  scores                Score[]                       // Scores that reference this domain template

  @@index([createdById])
  @@index([slug])
  @@map("domain_templates")
}

// Junction table for Assessment Templates <-> Domain Templates (many-to-many)
model AssessmentTemplateDomain {
  id                    String              @id @default(cuid())
  assessmentTemplateId  String
  domainTemplateId      String
  order                 Int                 // Order in which domains appear in the assessment
  isRequired            Boolean             @default(true) // Whether this domain is required for the assessment
  
  // Relationships
  assessmentTemplate    AssessmentTemplate  @relation(fields: [assessmentTemplateId], references: [id], onDelete: Cascade)
  domainTemplate        DomainTemplate      @relation(fields: [domainTemplateId], references: [id], onDelete: Cascade)

  @@unique([assessmentTemplateId, domainTemplateId])
  @@index([assessmentTemplateId])
  @@index([domainTemplateId])
  @@map("assessment_template_domains")
}

// Assessment Template Version History
model AssessmentTemplateVersion {
  id                    String                        @id @default(cuid())
  assessmentTemplateId  String                        // Reference to current template
  version               Int                           // Version number
  name                  String                        // Name at this version
  slug                  String                        // Slug at this version
  description           String?                       // Description at this version
  instructions          String?                       // Instructions at this version
  isActive              Boolean                       // Active status at this version
  domainSnapshot        Json                          // Snapshot of domain configuration at this version
  changeDescription     String?                       // Description of what changed
  createdById           String                        // Who made this version
  createdAt             DateTime                      @default(now())
  
  // Relationships
  assessmentTemplate    AssessmentTemplate            @relation(fields: [assessmentTemplateId], references: [id], onDelete: Cascade)
  createdBy             User                          @relation("AssessmentVersionsCreated", fields: [createdById], references: [id])

  @@unique([assessmentTemplateId, version])
  @@index([assessmentTemplateId])
  @@map("assessment_template_versions")
}

// Domain Template Version History
model DomainTemplateVersion {
  id                    String                        @id @default(cuid())
  domainTemplateId      String                        // Reference to current template
  version               Int                           // Version number
  name                  String                        // Name at this version
  slug                  String                        // Slug at this version
  description           String?                       // Description at this version
  questions             Json                          // Questions at this version
  resources             Json?                         // Resources at this version
  scoringConfig         Json?                         // Scoring config at this version
  changeDescription     String?                       // Description of what changed
  createdById           String                        // Who made this version
  createdAt             DateTime                      @default(now())
  
  // Relationships
  domainTemplate        DomainTemplate                @relation(fields: [domainTemplateId], references: [id], onDelete: Cascade)
  createdBy             User                          @relation("DomainVersionsCreated", fields: [createdById], references: [id])

  @@unique([domainTemplateId, version])
  @@index([domainTemplateId])
  @@map("domain_template_versions")
}

model ShareableLink {
  id           String           @id @default(cuid())
  shareCode    String           @unique
  assessmentId String
  createdById  String
  privacy      ShareLinkPrivacy @default(PRIVATE)
  password     String?
  expiresAt    DateTime?
  isActive     Boolean          @default(true)
  viewCount    Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  assessment   Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  createdBy    User             @relation("ShareLinksCreated", fields: [createdById], references: [id])

  @@index([shareCode])
  @@index([assessmentId])
  @@index([createdById])
  @@index([isActive])
  @@map("shareable_links")
}

model ChatSession {
  id        String          @id @default(cuid())
  title     String
  type      ChatSessionType
  userId    String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  messages  ChatMessage[]
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("chat_sessions")
}

model ChatMessage {
  id           String       @id @default(cuid())
  assessmentId String?
  sessionId    String?
  role         MessageRole
  content      String
  sources      Json?
  timestamp    DateTime     @default(now())
  assessment   Assessment?  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  session      ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([sessionId])
  @@map("chat_messages")
}

model Score {
  id                 String            @id @default(cuid())
  assessmentId       String
  domain             AssessmentDomain? // Made optional for backward compatibility
  domainTemplateId   String?           // New: Reference to domain template
  domainName         String?           // Denormalized domain name for performance
  rawScore           Float
  riskLevel          RiskLevel
  confidence         Float
  timestamp          DateTime          @default(now())
  questionsAnswered  Int
  totalPossible      Int
  wasTerminatedEarly Boolean           @default(false)
  assessment         Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  domainTemplate     DomainTemplate?   @relation(fields: [domainTemplateId], references: [id], onDelete: SetNull)

  @@index([assessmentId])
  @@index([domainTemplateId])
  @@map("scores")
}

model Recommendation {
  id           String     @id @default(cuid())
  assessmentId String
  userId       String
  title        String
  content      String
  category     String?
  priority     Int        @default(1)
  isBookmarked Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assessmentId])
  @@index([isBookmarked])
  @@map("recommendations")
}

model ResourceLibrary {
  id          String   @id @default(cuid())
  title       String
  description String?
  url         String
  category    String   // e.g., "Mental Health", "Parenting", "Education", "Support Services"
  tags        String[] // Searchable tags for filtering
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     User     @relation("ResourceLibraryCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([isActive])
  @@index([createdBy])
  @@map("resource_library")
}

model QuestionSet {
  id                         String            @id @default(cuid())
  domain                     AssessmentDomain  @unique
  name                       String
  description                String?
  isActive                   Boolean           @default(true)
  order                      Int
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  clinicallySignificantScore Int?
  displayName                String?
  multiPartLogic             Json?
  prerequisites              Json?
  skipConditions             Json?
  totalPossibleScore         Int?
  questions                  Question[]
  terminationRules           TerminationRule[]

  @@index([domain, isActive])
  @@map("question_sets")
}

model Question {
  id               String      @id @default(cuid())
  questionSetId    String
  text             String
  order            Int
  isGatingQuestion Boolean     @default(false)
  weight           Int         @default(1)
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  questionSet      QuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)

  @@unique([questionSetId, order])
  @@index([questionSetId, isActive])
  @@map("questions")
}

model TerminationRule {
  id                   String      @id @default(cuid())
  questionSetId        String
  name                 String
  description          String?
  minimumYesToContinue Int
  checkAfterQuestion   Int
  isActive             Boolean     @default(true)
  createdAt            DateTime    @default(now())
  questionSet          QuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)

  @@index([questionSetId, isActive])
  @@map("termination_rules")
}

model QuestionResponse {
  id           String     @id @default(cuid())
  assessmentId String
  questionId   String
  response     Boolean
  timestamp    DateTime   @default(now())
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, questionId])
  @@index([assessmentId])
  @@map("question_responses")
}

model License {
  id             String        @id @default(cuid())
  licenseKey     String        @unique
  type           LicenseType   @default(TRIAL)
  status         LicenseStatus @default(ACTIVE)
  maxUsers       Int           @default(1)
  maxAssessments Int?
  maxConversationalAssessments Int?
  maxConversationalReports Int?
  features       Json?
  validFrom      DateTime      @default(now())
  validUntil     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          UserLicense[]

  @@index([licenseKey])
  @@index([status])
  @@map("licenses")
}

model Organization {
  id            String         @id @default(cuid())
  name          String
  email         String?
  phone         String?
  address       String?
  billingEmail  String?
  taxId         String?
  industry      String?
  employeeCount String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  // Custom branding/white-label fields
  customDomain  String?        @unique // e.g., "client.aidiagnostic.com" or "assessments.clientcompany.com"
  logo          String?        // URL or path to custom logo
  primaryColor  String?        // Hex color code for primary branding
  secondaryColor String?       // Hex color code for secondary branding
  headerTitle   String?        // Custom title shown in app header
  footerText    String?        // Custom footer text
  
  licenses      License[]
  subscriptions Subscription[]
  users         User[]
  subAccounts   SubAccount[]

  @@map("organizations")
}

model UserLicense {
  id                              String   @id @default(cuid())
  userId                          String
  licenseId                       String
  assignedAt                      DateTime @default(now())
  assignedBy                      String?
  isActive                        Boolean  @default(true)
  assessmentsAllowed              Int      @default(0)  // Number of regular assessments this license allows (incremented on purchase)
  assessmentsUsed                 Int      @default(0)  // Number of regular assessments actually used
  conversationalAssessmentsAllowed Int     @default(0)  // Number of conversational assessments allowed ($9 addon)
  conversationalAssessmentsUsed   Int      @default(0)  // Number of conversational assessments actually used
  conversationalReportsAllowed    Int      @default(0)
  conversationalReportsUsed       Int      @default(0)
  license                         License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  user                            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, licenseId])
  @@index([userId])
  @@index([licenseId])
  @@map("user_licenses")
}

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  status               SubscriptionStatus @default(TRIALING)
  priceId              String?
  quantity             Int                @default(1)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  cancelAt             DateTime?
  canceledAt           DateTime?
  metadata             Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
  @@map("subscriptions")
}

model Payment {
  id                    String   @id @default(cuid())
  userId                String
  stripePaymentIntentId String   @unique
  stripeCustomerId      String?
  amount                Int      // Amount in cents
  currency              String   @default("usd")
  status                String   // SUCCEEDED, FAILED, etc.
  planType              String?  // Type of plan purchased
  plan                  String?  // Specific plan name
  childName             String?  // Child name for assessment
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("payments")
}

model UsageMetrics {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @default(now()) @db.Date
  assessments Int      @default(0)
  pdfReports  Int      @default(0)
  apiCalls    Int      @default(0)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("usage_metrics")
}

model PlatformSettings {
  id                    String   @id @default(cuid())

  // Global Assessment Configuration
  globalTrialAssessmentId     String?  // Assessment template for trial users
  globalRegularAssessmentId   String?  // Assessment template for regular users

  // Platform-wide settings
  maintenanceMode       Boolean  @default(false)
  registrationEnabled   Boolean  @default(true)
  trialAssessmentsEnabled Boolean @default(true)

  // AI Configuration
  aiReportsEnabled      Boolean  @default(true)
  maxAiReportsPerUser   Int      @default(10)
  maxConversationalSessionsPerUser Int @default(10)

  // Email / SES Configuration
  emailSendingEnabled   Boolean  @default(true)  // Manual override to disable all email sending
  sesMonthlyBudget      Decimal  @default(5.00)  // Monthly budget limit in USD

  // Timestamps
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  updatedBy            String   // User ID who made the change

  // Relations
  globalTrialAssessment   AssessmentTemplate? @relation("GlobalTrialAssessment", fields: [globalTrialAssessmentId], references: [id])
  globalRegularAssessment AssessmentTemplate? @relation("GlobalRegularAssessment", fields: [globalRegularAssessmentId], references: [id])

  @@map("platform_settings")
}

// SES Email Usage Tracking - Individual email sends
model SESUsage {
  id              String   @id @default(cuid())
  emailsSent      Int      @default(1)       // Number of emails in this batch
  estimatedCost   Decimal  @db.Decimal(10, 6) // Cost in USD (e.g., 0.0001 per email)
  recipient       String?                     // Optional: track recipient for audit
  emailType       String?                     // Optional: type of email (e.g., "PDF Report", "Welcome")
  sentAt          DateTime @default(now())

  @@index([sentAt])
  @@map("ses_usage")
}

// SES Monthly Totals - Aggregated monthly cost tracking
model SESMonthlyTotal {
  id              String   @id @default(cuid())
  month           DateTime @db.Date           // First day of the month (e.g., 2025-01-01)
  totalEmailsSent Int      @default(0)        // Total emails sent this month
  totalCost       Decimal  @default(0) @db.Decimal(10, 6) // Total cost in USD
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([month])
  @@index([month])
  @@map("ses_monthly_totals")
}

// Email Log - Detailed tracking for rate limiting and abuse prevention
model EmailLog {
  id             String   @id @default(cuid())
  userId         String?  // Null for system emails
  user           User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  recipientEmail String
  emailType      String   // "WELCOME", "PASSWORD_RESET", "ASSESSMENT_REPORT", "LICENSE_NOTIFICATION", etc.
  subject        String
  status         String   // "SENT", "FAILED", "BOUNCED", "COMPLAINED"
  messageId      String?  // SES message ID
  errorMessage   String?

  sentAt         DateTime @default(now())

  @@index([userId, sentAt])
  @@index([recipientEmail, sentAt])
  @@index([sentAt])
  @@index([emailType])
  @@index([status])
  @@map("email_logs")
}

// Notification Preferences - User email notification settings
model NotificationPreferences {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Assessment notifications
  assessmentComplete    Boolean  @default(true)   // When assessment is completed
  assessmentShared      Boolean  @default(true)   // When someone shares an assessment with them

  // License notifications
  licenseExpiring       Boolean  @default(true)   // License expiration warnings
  licenseRenewed        Boolean  @default(true)   // License renewal confirmations

  // Recommendation notifications
  newRecommendation     Boolean  @default(true)   // New AI recommendations available

  // Summary notifications
  weeklySummary         Boolean  @default(false)  // Weekly assessment summary (opt-in)
  monthlySummary        Boolean  @default(false)  // Monthly usage summary (opt-in)

  // Account notifications
  accountUpdate         Boolean  @default(true)   // Important account changes
  securityAlert         Boolean  @default(true)   // Security-related notifications (always on by default)
  productUpdates        Boolean  @default(false)  // New features and updates (opt-in)

  // Marketing (opt-in only)
  marketingEmails       Boolean  @default(false)  // Promotional emails

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@map("notification_preferences")
}

