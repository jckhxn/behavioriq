generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

enum Role {
  USER
  ADMIN
}

enum AssessmentStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum ChatSessionType {
  ASSESSMENT
  KNOWLEDGE
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  VERY_HIGH
}

enum AssessmentDomain {
  ANTISOCIAL
  VIOLENCE
  ATTENTION
  EMOTIONAL
  CONDUCT
}

enum LicenseType {
  TRIAL
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  UNPAID
}

enum DocumentCategory {
  POLICY
  PROCEDURE
  GUIDELINE
  MANUAL
  ASSESSMENT_TOOL
  REFERENCE
  OTHER
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  name          String?
  password      String
  role          Role            @default(USER)
  isActive      Boolean         @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  // Organization relationship
  organization    Organization? @relation(fields: [organizationId], references: [id])
  organizationId  String?
  
  // Relations
  documents     Document[]
  assessments   Assessment[]
  chatSessions  ChatSession[]
  licenses      UserLicense[]
  usageMetrics  UsageMetrics[]
  recommendations Recommendation[]
  
  @@index([organizationId])
  @@map("users")
}

model Document {
  id            String           @id @default(cuid())
  title         String
  fileName      String
  fileType      String
  fileSize      Int
  category      DocumentCategory @default(OTHER)
  content       String?          @db.Text
  uploadedBy    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  
  chunks        DocumentChunk[]
  
  @@index([userId])
  @@index([category])
  @@map("documents")
}

model DocumentChunk {
  id            String                    @id @default(cuid())
  title         String
  content       String                    @db.Text
  category      DocumentCategory
  chunkIndex    Int
  embedding     Unsupported("vector(1536)")?
  document      Document                  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId    String
  userId        String
  createdAt     DateTime                  @default(now())
  
  @@index([documentId])
  @@index([userId])
  @@map("document_chunks")
}

model Assessment {
  id            String           @id @default(cuid())
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  subjectName   String
  status        AssessmentStatus @default(IN_PROGRESS)
  currentDomain AssessmentDomain? // Track current domain being assessed
  currentQuestionOrder Int?       // Track current question within domain
  startedAt     DateTime         @default(now())
  completedAt   DateTime?

  messages      ChatMessage[]
  scores        Score[]
  responses     QuestionResponse[]
  recommendations Recommendation[]

  @@index([userId])
  @@index([status])
  @@map("assessments")
}

model ChatSession {
  id            String          @id @default(cuid())
  title         String
  type          ChatSessionType
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  messages      ChatMessage[]
  
  @@index([userId])
  @@index([type])
  @@map("chat_sessions")
}

model ChatMessage {
  id            String       @id @default(cuid())
  assessment    Assessment?  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId  String?
  session       ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId     String?
  role          MessageRole
  content       String       @db.Text
  sources       Json?        // Array of document references used for response
  timestamp     DateTime     @default(now())
  
  @@index([assessmentId])
  @@index([sessionId])
  @@map("chat_messages")
}

model Score {
  id            String           @id @default(cuid())
  assessment    Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId  String
  domain        AssessmentDomain
  rawScore      Float
  totalPossible Int              // Total possible points for this domain
  questionsAnswered Int          // Number of questions answered (for early termination tracking)
  riskLevel     RiskLevel
  confidence    Float            // 0 to 1
  wasTerminatedEarly Boolean     @default(false) // True if domain was skipped due to early termination
  timestamp     DateTime         @default(now())

  @@unique([assessmentId, domain, timestamp])
  @@index([assessmentId])
  @@map("scores")
}

model Recommendation {
  id            String     @id @default(cuid())
  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId  String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  title         String     // Summary title for the recommendation
  content       String     @db.Text // Full AI-generated recommendation text
  category      String?    // Category like "Immediate Action", "Therapeutic", etc.
  priority      Int        @default(1) // 1-5 priority level
  isBookmarked  Boolean    @default(false) // User can bookmark important recommendations
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId])
  @@index([assessmentId])
  @@index([isBookmarked])
  @@map("recommendations")
}

model QuestionSet {
  id                        String           @id @default(cuid())
  domain                    AssessmentDomain
  name                      String
  displayName               String?          // User-friendly display name
  description               String?
  isActive                  Boolean          @default(true)
  order                     Int              // Order of domains in assessment
  totalPossibleScore        Int?             // Maximum possible score for clinical evaluation
  clinicallySignificantScore Int?            // Threshold score for clinical significance
  skipConditions            Json?            // JSON array of skip conditions
  prerequisites             Json?            // JSON array of prerequisite conditions
  multiPartLogic            Json?            // JSON configuration for multi-part question logic
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  questions     Question[]
  terminationRules TerminationRule[]

  @@unique([domain])
  @@index([domain, isActive])
  @@map("question_sets")
}

model Question {
  id            String      @id @default(cuid())
  questionSet   QuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  questionSetId String
  text          String      @db.Text
  order         Int
  isGatingQuestion Boolean  @default(false) // If true, failing this can trigger early termination
  weight        Int         @default(1)     // Point value for "Yes" answer
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([questionSetId, order])
  @@index([questionSetId, isActive])
  @@map("questions")
}

model TerminationRule {
  id            String      @id @default(cuid())
  questionSet   QuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  questionSetId String
  name          String
  description   String?
  minimumYesToContinue Int // Minimum "yes" answers needed to continue with domain
  checkAfterQuestion Int   // Check rule after this question number
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())

  @@index([questionSetId, isActive])
  @@map("termination_rules")
}

model QuestionResponse {
  id            String     @id @default(cuid())
  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId  String
  questionId    String     // Store question ID as string (no foreign key for Early Detection Screener)
  response      Boolean    // true for "Yes", false for "No"
  timestamp     DateTime   @default(now())

  @@unique([assessmentId, questionId])
  @@index([assessmentId])
  @@map("question_responses")
}

model License {
  id              String        @id @default(cuid())
  licenseKey      String        @unique
  type            LicenseType   @default(TRIAL)
  status          LicenseStatus @default(ACTIVE)
  maxUsers        Int           @default(1)
  maxAssessments  Int?          // null = unlimited
  features        Json?         // Feature flags as JSON
  validFrom       DateTime      @default(now())
  validUntil      DateTime?     // null = no expiration
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String?
  users           UserLicense[]
  
  @@index([licenseKey])
  @@index([status])
  @@map("licenses")
}

model Organization {
  id                String    @id @default(cuid())
  name              String
  email             String?
  phone             String?
  address           String?
  billingEmail      String?
  taxId             String?
  industry          String?
  employeeCount     String?   // e.g., "1-10", "11-50", etc.
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Relations
  licenses          License[]
  subscriptions     Subscription[]
  users             User[]
  
  @@map("organizations")
}

model UserLicense {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  license     License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  licenseId   String
  assignedAt  DateTime @default(now())
  assignedBy  String?  // User ID who assigned this license
  isActive    Boolean  @default(true)
  
  @@unique([userId, licenseId])
  @@index([userId])
  @@index([licenseId])
  @@map("user_licenses")
}

model Subscription {
  id                    String             @id @default(cuid())
  organization          Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId        String
  stripeSubscriptionId  String?            @unique
  stripeCustomerId      String?
  status                SubscriptionStatus @default(TRIALING)
  priceId               String?            // Stripe price ID
  quantity              Int                @default(1)
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  trialStart            DateTime?
  trialEnd              DateTime?
  cancelAtPeriodEnd     Boolean            @default(false)
  cancelAt              DateTime?
  canceledAt            DateTime?
  metadata              Json?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  
  @@index([organizationId])
  @@index([status])
  @@map("subscriptions")
}

model UsageMetrics {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  date           DateTime @default(now()) @db.Date
  assessments    Int      @default(0)
  pdfReports     Int      @default(0)
  apiCalls       Int      @default(0)
  
  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("usage_metrics")
}