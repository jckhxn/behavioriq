generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

enum Role {
  USER
  ADMIN
}

enum AssessmentStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum ChatSessionType {
  ASSESSMENT
  KNOWLEDGE
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  VERY_HIGH
}

enum AssessmentDomain {
  ANTISOCIAL
  VIOLENCE
  ATTENTION
  EMOTIONAL
  CONDUCT
}

enum DocumentCategory {
  POLICY
  PROCEDURE
  GUIDELINE
  MANUAL
  ASSESSMENT_TOOL
  REFERENCE
  OTHER
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  name          String?
  password      String
  role          Role            @default(USER)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  documents     Document[]
  assessments   Assessment[]
  chatSessions  ChatSession[]
  
  @@map("users")
}

model Document {
  id            String           @id @default(cuid())
  title         String
  fileName      String
  fileType      String
  fileSize      Int
  category      DocumentCategory @default(OTHER)
  content       String?          @db.Text
  uploadedBy    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  
  chunks        DocumentChunk[]
  
  @@index([userId])
  @@index([category])
  @@map("documents")
}

model DocumentChunk {
  id            String                    @id @default(cuid())
  title         String
  content       String                    @db.Text
  category      DocumentCategory
  chunkIndex    Int
  embedding     Unsupported("vector(1536)")?
  document      Document                  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId    String
  userId        String
  createdAt     DateTime                  @default(now())
  
  @@index([documentId])
  @@index([userId])
  @@map("document_chunks")
}

model Assessment {
  id            String           @id @default(cuid())
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  subjectName   String
  status        AssessmentStatus @default(IN_PROGRESS)
  startedAt     DateTime         @default(now())
  completedAt   DateTime?
  
  messages      ChatMessage[]
  scores        Score[]
  
  @@index([userId])
  @@index([status])
  @@map("assessments")
}

model ChatSession {
  id            String          @id @default(cuid())
  title         String
  type          ChatSessionType
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  messages      ChatMessage[]
  
  @@index([userId])
  @@index([type])
  @@map("chat_sessions")
}

model ChatMessage {
  id            String       @id @default(cuid())
  assessment    Assessment?  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId  String?
  session       ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId     String?
  role          MessageRole
  content       String       @db.Text
  sources       Json?        // Array of document references used for response
  timestamp     DateTime     @default(now())
  
  @@index([assessmentId])
  @@index([sessionId])
  @@map("chat_messages")
}

model Score {
  id            String           @id @default(cuid())
  assessment    Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId  String
  domain        AssessmentDomain
  rawScore      Float
  riskLevel     RiskLevel
  confidence    Float            // 0 to 1
  timestamp     DateTime         @default(now())
  
  @@unique([assessmentId, domain, timestamp])
  @@index([assessmentId])
  @@map("scores")
}