  id           String     @id @default(cuid())
  assessmentId String
  domainName   String     // "Anxiety", "Mood", "Behavior", etc.
  flagged      Boolean    // true = "May warrant follow-up"
  rawScore     Float?     // Hidden unless feature flag enabled
  percentile   Float?     // Hidden unless feature flag enabled
  createdAt    DateTime   @default(now())
  
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  
  @@index([assessmentId])
  @@index([domainName])
  @@map("domain_indicators")
  @@schema("public")
}

model TeacherObservation {
  id         String   @id @default(cuid())
  teacherId  String
  studentId  String
  content    String   // Free text observation
  structured Json?    // Optional structured fields
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  teacher    Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  @@index([teacherId])
  @@index([studentId])
  @@index([createdAt])
  @@map("teacher_observations")
  @@schema("public")
}

model PushNotification {
  id     String   @id @default(cuid())
  userId String   @map("user_id")
  title  String
  body   String
  data   Json?
  sentAt DateTime @default(now()) @map("sent_at")
  user   User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sentAt])
  @@map("push_notifications")
  @@schema("public")
}

model IntentAcknowledgment {
  id        String   @id @default(cuid())
  userId    String
  studentId String
  action    String   // "VIEW_STUDENT_DETAIL" | "VIEW_SCREENING_SUMMARY"
  ipAddress String?
  createdAt DateTime @default(now())
  
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([studentId])
  @@index([action])
  @@map("intent_acknowledgments")
  @@schema("public")
}
