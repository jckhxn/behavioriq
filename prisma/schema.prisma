generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "multiSchema"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  extensions        = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
  schemas           = ["public", "auth"]
}

model BannedDevice {
  deviceId  String   @id
  reason    String?
  createdAt DateTime @default(now())
  @@schema("public")
}

model BannedUser {
  userId    String   @id
  reason    String?
  createdAt DateTime @default(now())
  @@schema("public")
}

model BannedEmail {
  email     String   @id
  reason    String?
  createdAt DateTime @default(now())
  @@schema("public")
}

model AffiliateReferrer {
  id                      String                            @id @default(cuid())
  userId                  String                            @unique
  refCode                 String                            @unique
  status                  String                            @default("active")
  stripeConnectAccountId  String?
  lastPayoutDate          DateTime?
  lifetimeEarningsCents   Int                               @default(0)
  lifetimePaidOutCents    Int                               @default(0)
  createdAt               DateTime                          @default(now())
  commissions             AffiliateCommission[]             @relation("ReferrerCommissions")
  notificationPreferences AffiliateNotificationPreferences?
  payouts                 AffiliatePayout[]                 @relation("ReferrerPayouts")
  payoutPreferences       AffiliatePayoutPreferences?
  user                    User                              @relation(fields: [userId], references: [id])

  @@index([status])
  @@schema("public")
}

model AffiliateClick {
  id        String   @id @default(cuid())
  refCode   String
  sessionId String
  ip        String?
  ua        String?
  utm       Json?
  createdAt DateTime @default(now())

  @@index([refCode])
  @@index([sessionId])
  @@index([createdAt])
  @@schema("public")
}

model AffiliateAttribution {
  id             String   @id @default(cuid())
  refCode        String
  prospectUserId String   @unique
  clickId        String?
  deviceId       String?
  ip             String?
  utm            Json?
  model          String   @default("last_non_direct")
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  @@index([refCode])
  @@index([createdAt])
  @@schema("public")
}

model AffiliateCommission {
  id             String            @id @default(cuid())
  refCode        String
  referrerId     String
  referredUserId String
  event          String
  amountCents    Int
  status         String            @default("pending")
  voidReason     String?
  holdUntil      DateTime?
  orderId        String?           @unique
  createdAt      DateTime          @default(now())
  referrer       AffiliateReferrer @relation("ReferrerCommissions", fields: [referrerId], references: [id])

  @@index([referrerId])
  @@index([status])
  @@index([createdAt])
  @@index([holdUntil])
  @@index([referrerId, status])
  @@schema("public")
}

model AffiliatePayout {
  id                   String            @id @default(cuid())
  referrerId           String
  amountCents          Int
  status               String            @default("pending")
  provider             String            @default("stripe_connect")
  transferId           String?
  failureReason        String?
  payoutMethod         String?           @default("stripe_connect")
  estimatedArrivalDate DateTime?
  actualArrivalDate    DateTime?
  feesCents            Int               @default(0)
  netAmountCents       Int?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  referrer             AffiliateReferrer @relation("ReferrerPayouts", fields: [referrerId], references: [id])

  @@index([referrerId])
  @@index([status])
  @@index([createdAt])
  @@index([estimatedArrivalDate])
  @@schema("public")
}

model AffiliatePayoutPreferences {
  id                      String            @id @default(cuid())
  referrerId              String            @unique
  minPayoutThresholdCents Int               @default(5000)
  payoutFrequency         String            @default("auto")
  autoPayoutEnabled       Boolean           @default(true)
  payoutDayOfMonth        Int?
  payoutDayOfWeek         Int?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  referrer                AffiliateReferrer @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@schema("public")
}

model AffiliateNotificationPreferences {
  id                       String            @id @default(cuid())
  referrerId               String            @unique
  emailOnPayout            Boolean           @default(true)
  emailOnCommissionEarned  Boolean           @default(true)
  emailOnCommissionPayable Boolean           @default(true)
  emailWeeklySummary       Boolean           @default(false)
  emailMonthlySummary      Boolean           @default(false)
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  referrer                 AffiliateReferrer @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@schema("public")
}

model User {
  id                                               String                      @id @default(cuid())
  email                                            String                      @unique
  name                                             String?
  password                                         String
  role                                             Role                        @default(USER)
  createdAt                                        DateTime                    @default(now())
  updatedAt                                        DateTime                    @updatedAt
  isActive                                         Boolean                     @default(true)
  lastLoginAt                                      DateTime?
  firstPaidReportAt                                DateTime?
  organizationId                                   String?
  parentUserId                                     String?
  onboardingCompleted                              Boolean                     @default(false)
  onboardingStep                                   Int                         @default(0)
  onboardingSkipped                                Boolean                     @default(false)
  stripeCustomerId                                 String?                     @unique @db.VarChar
  avatarUrl                                        String?
  emailVerified                                    Boolean                     @default(false)
  emailVerificationToken                           String?                     @unique
  emailVerificationTokenExpiresAt                  DateTime?
  pendingEmail                                     String?
  credits                                          Int                         @default(0)
  isDeactivated                                    Boolean                     @default(false)
  deactivatedAt                                    DateTime?
  deletionRequestedAt                              DateTime?
  affiliateReferrer                                AffiliateReferrer?
  creditTransactions                               CreditTransaction[]
  createdEmailTemplates                            EmailTemplate[]             @relation("EmailTemplatesCreated")
  createdEmailTemplateVersions                     EmailTemplateVersion[]      @relation("EmailTemplateVersionsCreated")
  magicLinkTokens                                  MagicLinkToken[]
  generatedAIReports                               AIReport[]
  createdAssessmentVersions                        AssessmentTemplateVersion[] @relation("AssessmentVersionsCreated")
  createdAssessmentTemplates                       AssessmentTemplate[]        @relation("AssessmentTemplatesCreated")
  assessments                                      Assessment[]
  chatSessions                                     ChatSession[]
  childProfiles                                    ChildProfile[]
  conversationalSessions                           ConversationalSession[]
  documents                                        Document[]
  createdDomainVersions                            DomainTemplateVersion[]     @relation("DomainVersionsCreated")
  createdDomainTemplates                           DomainTemplate[]            @relation("DomainTemplatesCreated")
  emailLogs                                        EmailLog[]
  loginTokens                                      LoginToken[]
  notificationPreferences                          NotificationPreferences?
  passkeys                                         Passkey[]
  payments                                         Payment[]
  recommendations                                  Recommendation[]
  createdResources                                 ResourceLibrary[]           @relation("ResourceLibraryCreator")
  shareLinks                                       ShareableLink[]             @relation("ShareLinksCreated")
  managedSubAccounts                               SubAccount[]                @relation("ManagedBy")
  subAccountProfile                                SubAccount?                 @relation("SubAccountUser")
  teacherProfile                                   Teacher?
  counselorProfile                                 Counselor?
  telemetry_events_telemetry_events_user_idTousers TelemetryEvent[]            @relation("telemetry_events_user_idTousers")
  telemetryEvents                                  TelemetryEvent[]
  usageMetrics                                     UsageMetrics[]
  licenses                                         UserLicense[]
  pushNotifications                                PushNotification[]
  upsellState                                      UserUpsellState?
  organization                                     Organization?               @relation(fields: [organizationId], references: [id])
  parentUser                                       User?                       @relation("UserSubAccounts", fields: [parentUserId], references: [id])
  subAccounts                                      User[]                      @relation("UserSubAccounts")

  @@index([organizationId])
  @@index([parentUserId])
  @@map("users")
  @@schema("public")
}

model Passkey {
  id           String   @id @default(cuid())
  userId       String
  name         String
  credentialId String   @unique
  publicKey    String
  counter      BigInt
  transports   String[]
  createdAt    DateTime @default(now())
  lastUsed     DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([credentialId])
  @@map("passkeys")
  @@schema("public")
}

model PasskeyChallenge {
  id        String   @id @default(cuid())
  userId    String
  challenge String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([challenge])
  @@index([expiresAt])
  @@map("passkey_challenges")
  @@schema("public")
}

model SubAccount {
  id              String       @id @default(cuid())
  userId          String       @unique
  managedByUserId String
  organizationId  String
  displayName     String
  description     String?
  maxAssessments  Int?
  maxUsers        Int          @default(1)
  settings        Json?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  managedBy       User         @relation("ManagedBy", fields: [managedByUserId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User         @relation("SubAccountUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([managedByUserId])
  @@index([organizationId])
  @@index([isActive])
  @@map("sub_accounts")
  @@schema("public")
}

model Document {
  id         String           @id @default(cuid())
  title      String
  fileName   String
  fileType   String
  fileSize   Int
  category   DocumentCategory @default(OTHER)
  content    String?
  userId     String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  chunks     DocumentChunk[]
  uploadedBy User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@map("documents")
  @@schema("public")
}

model DocumentChunk {
  id         String                 @id @default(cuid())
  title      String
  content    String
  category   DocumentCategory
  chunkIndex Int
  embedding  Unsupported("vector")?
  documentId String
  userId     String
  createdAt  DateTime               @default(now())
  document   Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId])
  @@map("document_chunks")
  @@schema("public")
}

model Assessment {
  id                        String                 @id @default(cuid())
  userId                    String?
  subjectName               String
  status                    AssessmentStatus       @default(IN_PROGRESS)
  mode                      AssessmentMode         @default(TRIAL)
  sessionId                 String?
  startedAt                 DateTime               @default(now())
  completedAt               DateTime?
  paidAt                    DateTime?
  currentDomain             AssessmentDomain?
  currentQuestionOrder      Int?
  shortId                   String?                @unique
  assessmentTemplateId      String?
  isConversational          Boolean                @default(false)
  hasEnhancedReport         Boolean                @default(false)
  enhancedReportPurchasedAt DateTime?
  aiReportGenerated         Boolean                @default(false)
  childResponses            Json?
  enhancedAnalysis          Json?
  childprofileid            String?
  affiliateRefCode          String?
  aiReport                  AIReport?
  assessmentTemplate        AssessmentTemplate?    @relation("AssessmentFromTemplate", fields: [assessmentTemplateId], references: [id])
  user                      User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  childProfile              ChildProfile?          @relation(fields: [childprofileid], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_assessment_childprofile")
  messages                  ChatMessage[]
  conversationalSession     ConversationalSession?
  responses                 QuestionResponse[]
  recommendations           Recommendation[]
  scores                    Score[]
  shareableLinks            ShareableLink[]
  studentAssessment         StudentAssessment?
  domainIndicators          DomainIndicator[]

  @@index([userId])
  @@index([status])
  @@index([shortId])
  @@index([assessmentTemplateId])
  @@index([hasEnhancedReport])
  @@index([mode])
  @@index([sessionId])
  @@map("assessments")
  @@schema("public")
}

model AIReport {
  id                String     @id @default(cuid())
  assessmentId      String     @unique
  content           String
  summary           String?
  riskLevel         RiskLevel
  generatedAt       DateTime   @default(now())
  generatedByUserId String
  reportOptions     Json
  pdfPath           String?
  pdfSize           Int?
  emailsSent        Int        @default(0)
  lastAccessedAt    DateTime?
  isArchived        Boolean    @default(false)
  assessment        Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  generatedBy       User       @relation(fields: [generatedByUserId], references: [id])

  @@index([assessmentId])
  @@index([generatedByUserId])
  @@index([generatedAt])
  @@map("ai_reports")
  @@schema("public")
}

model AssessmentTemplate {
  id                    String                      @id @default(cuid())
  name                  String
  description           String?
  createdById           String
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  instructions          String?
  isActive              Boolean                     @default(true)
  slug                  String                      @unique
  version               Int                         @default(1)
  domains               AssessmentTemplateDomain[]
  versions              AssessmentTemplateVersion[]
  createdBy             User                        @relation("AssessmentTemplatesCreated", fields: [createdById], references: [id])
  assessments           Assessment[]                @relation("AssessmentFromTemplate")
  globalRegularSettings PlatformSettings[]          @relation("GlobalRegularAssessment")
  globalTrialSettings   PlatformSettings[]          @relation("GlobalTrialAssessment")

  @@index([createdById])
  @@index([isActive])
  @@index([slug])
  @@map("assessment_templates")
  @@schema("public")
}

model DomainTemplate {
  id                  String                     @id @default(cuid())
  name                String
  slug                String                     @unique
  description         String?
  questions           Json
  resources           Json?
  scoringConfig       Json
  createdById         String
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  version             Int                        @default(1)
  assessmentTemplates AssessmentTemplateDomain[]
  versions            DomainTemplateVersion[]
  createdBy           User                       @relation("DomainTemplatesCreated", fields: [createdById], references: [id])
  scores              Score[]

  @@index([createdById])
  @@index([slug])
  @@map("domain_templates")
  @@schema("public")
}

model AssessmentTemplateDomain {
  id                   String             @id @default(cuid())
  assessmentTemplateId String
  domainTemplateId     String
  order                Int
  isRequired           Boolean            @default(true)
  assessmentTemplate   AssessmentTemplate @relation(fields: [assessmentTemplateId], references: [id], onDelete: Cascade)
  domainTemplate       DomainTemplate     @relation(fields: [domainTemplateId], references: [id], onDelete: Cascade)

  @@unique([assessmentTemplateId, domainTemplateId])
  @@index([assessmentTemplateId])
  @@index([domainTemplateId])
  @@map("assessment_template_domains")
  @@schema("public")
}

model AssessmentTemplateVersion {
  id                   String             @id @default(cuid())
  assessmentTemplateId String
  version              Int
  name                 String
  slug                 String
  description          String?
  instructions         String?
  isActive             Boolean
  domainSnapshot       Json
  changeDescription    String?
  createdById          String
  createdAt            DateTime           @default(now())
  assessmentTemplate   AssessmentTemplate @relation(fields: [assessmentTemplateId], references: [id], onDelete: Cascade)
  createdBy            User               @relation("AssessmentVersionsCreated", fields: [createdById], references: [id])

  @@unique([assessmentTemplateId, version])
  @@index([assessmentTemplateId])
  @@map("assessment_template_versions")
  @@schema("public")
}

model DomainTemplateVersion {
  id                String         @id @default(cuid())
  domainTemplateId  String
  version           Int
  name              String
  slug              String
  description       String?
  questions         Json
  resources         Json?
  scoringConfig     Json?
  changeDescription String?
  createdById       String
  createdAt         DateTime       @default(now())
  createdBy         User           @relation("DomainVersionsCreated", fields: [createdById], references: [id])
  domainTemplate    DomainTemplate @relation(fields: [domainTemplateId], references: [id], onDelete: Cascade)

  @@unique([domainTemplateId, version])
  @@index([domainTemplateId])
  @@map("domain_template_versions")
  @@schema("public")
}

model ShareableLink {
  id                 String              @id @default(cuid())
  shareCode          String              @unique
  assessmentId       String
  createdById        String
  privacy            ShareLinkPrivacy    @default(PRIVATE)
  password           String?
  expiresAt          DateTime?
  isActive           Boolean             @default(true)
  viewCount          Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  assessment         Assessment          @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  createdBy          User                @relation("ShareLinksCreated", fields: [createdById], references: [id])
  studentAssessments StudentAssessment[]

  @@index([shareCode])
  @@index([assessmentId])
  @@index([createdById])
  @@index([isActive])
  @@map("shareable_links")
  @@schema("public")
}

model ChatSession {
  id        String          @id @default(cuid())
  title     String
  type      ChatSessionType
  userId    String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  messages  ChatMessage[]
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("chat_sessions")
  @@schema("public")
}

model ChatMessage {
  id           String       @id @default(cuid())
  assessmentId String?
  sessionId    String?
  role         MessageRole
  content      String
  sources      Json?
  timestamp    DateTime     @default(now())
  assessment   Assessment?  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  session      ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([sessionId])
  @@map("chat_messages")
  @@schema("public")
}

model Score {
  id                 String            @id @default(cuid())
  assessmentId       String
  domain             AssessmentDomain?
  rawScore           Float
  riskLevel          RiskLevel
  confidence         Float
  timestamp          DateTime          @default(now())
  questionsAnswered  Int
  totalPossible      Int
  wasTerminatedEarly Boolean           @default(false)
  domainName         String?
  domainTemplateId   String?
  assessment         Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  domainTemplate     DomainTemplate?   @relation(fields: [domainTemplateId], references: [id])

  @@index([assessmentId])
  @@index([domainTemplateId])
  @@map("scores")
  @@schema("public")
}

model Recommendation {
  id           String     @id @default(cuid())
  assessmentId String
  userId       String?
  title        String
  content      String
  category     String?
  priority     Int        @default(1)
  isBookmarked Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user         User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assessmentId])
  @@index([isBookmarked])
  @@map("recommendations")
  @@schema("public")
}

model ResourceLibrary {
  id          String   @id @default(cuid())
  title       String
  description String?
  url         String
  category    String
  tags        String[]
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     User     @relation("ResourceLibraryCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([isActive])
  @@index([createdBy])
  @@map("resource_library")
  @@schema("public")
}

model QuestionSet {
  id                         String            @id @default(cuid())
  domain                     AssessmentDomain  @unique
  name                       String
  description                String?
  isActive                   Boolean           @default(true)
  order                      Int
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  clinicallySignificantScore Int?
  displayName                String?
  multiPartLogic             Json?
  prerequisites              Json?
  skipConditions             Json?
  totalPossibleScore         Int?
  questions                  Question[]
  terminationRules           TerminationRule[]

  @@index([domain, isActive])
  @@map("question_sets")
  @@schema("public")
}

model Question {
  id               String      @id @default(cuid())
  questionSetId    String
  text             String
  order            Int
  isGatingQuestion Boolean     @default(false)
  weight           Int         @default(1)
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  isTrial          Boolean     @default(false)
  questionSet      QuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)

  @@unique([questionSetId, order])
  @@index([questionSetId, isActive])
  @@index([isTrial])
  @@map("questions")
  @@schema("public")
}

model TerminationRule {
  id                   String      @id @default(cuid())
  questionSetId        String
  name                 String
  description          String?
  minimumYesToContinue Int
  checkAfterQuestion   Int
  isActive             Boolean     @default(true)
  createdAt            DateTime    @default(now())
  questionSet          QuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)

  @@index([questionSetId, isActive])
  @@map("termination_rules")
  @@schema("public")
}

model QuestionResponse {
  id           String     @id @default(cuid())
  assessmentId String
  questionId   String
  response     String
  timestamp    DateTime   @default(now())
  score        Int        @default(0)
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, questionId])
  @@index([assessmentId])
  @@map("question_responses")
  @@schema("public")
}

model License {
  id                           String        @id @default(cuid())
  licenseKey                   String        @unique
  type                         LicenseType
  status                       LicenseStatus @default(ACTIVE)
  maxUsers                     Int           @default(1)
  maxAssessments               Int?
  features                     Json?
  validFrom                    DateTime      @default(now())
  validUntil                   DateTime?
  createdAt                    DateTime      @default(now())
  updatedAt                    DateTime      @updatedAt
  organizationId               String?
  maxConversationalReports     Int?
  maxConversationalAssessments Int?
  organization                 Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users                        UserLicense[]

  @@index([licenseKey])
  @@index([status])
  @@map("licenses")
  @@schema("public")
}

model Organization {
  id             String         @id @default(cuid())
  name           String
  email          String?
  phone          String?
  address        String?
  billingEmail   String?
  taxId          String?
  industry       String?
  employeeCount  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  customDomain   String?        @unique
  logo           String?
  primaryColor   String?
  secondaryColor String?
  headerTitle    String?
  footerText     String?
  districts      District[]
  licenses       License[]
  subAccounts    SubAccount[]
  subscriptions  Subscription[]
  users          User[]

  @@map("organizations")
  @@schema("public")
}

model UserLicense {
  id                           String    @id @default(cuid())
  userId                       String
  licenseId                    String
  assignedAt                   DateTime  @default(now())
  assignedBy                   String?
  isActive                     Boolean   @default(true)
  assessmentsAllowed           Int       @default(0)
  assessmentsUsed              Int       @default(0)
  conversationalReportsAllowed Int       @default(0)
  conversationalReportsUsed    Int       @default(0)
  lastCreditsRefreshedAt       DateTime? @db.Timestamptz(6)
  license                      License   @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  user                         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, licenseId])
  @@index([userId])
  @@index([licenseId])
  @@map("user_licenses")
  @@schema("public")
}

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  status               SubscriptionStatus @default(TRIALING)
  priceId              String?
  quantity             Int                @default(1)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  cancelAt             DateTime?
  canceledAt           DateTime?
  metadata             Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
  @@map("subscriptions")
  @@schema("public")
}

model Payment {
  id                    String   @id @default(cuid())
  userId                String?
  stripePaymentIntentId String   @unique
  stripeCustomerId      String?
  amount                Int
  currency              String   @default("usd")
  status                String
  planType              String?
  plan                  String?
  childName             String?
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
